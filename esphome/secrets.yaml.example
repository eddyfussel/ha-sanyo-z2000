# Copy this file to secrets.yaml and fill in your actual values.
# secrets.yaml is excluded from git via .gitignore.

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# Fallback hotspot (appears when WiFi connection fails)
ap_ssid: "Sanyo Fallback"
ap_password: "ChangeMe123"

# Generate with: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "REPLACE_WITH_32_BYTE_BASE64_KEY=="

# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
ota_password: "REPLACE_WITH_RANDOM_HEX_PASSWORD"
